# Cấu hình Database PostgreSQL cục bộ
# Hãy thay thế "user" và "password" bằng thông tin đăng nhập PostgreSQL của máy bạn
DATABASE_URL=postgresql://postgres:password123@localhost:5432/telegram_kpi

# Cấu hình Telegram Bot
# Bạn có thể lấy token này từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Cấu hình Web API
API_PORT=3000
