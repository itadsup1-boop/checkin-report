# ============================================================
# .env.example — Hệ Thống KPI Telegram Report
# Sao chép file này thành .env và điền thông tin thực tế vào
# ============================================================

# --- Database Password (dùng cho Docker) ---
# Mật khẩu PostgreSQL chạy trong Docker container
DB_PASSWORD=123456

# --- PostgreSQL Database ---
# Khi chạy Docker: KHÔNG cần sửa dòng này (docker-compose tự override)
# Khi chạy thủ công (non-Docker): điền thông tin thực tế
DATABASE_URL=postgresql://postgres:kpi_secret_2024@localhost:5432/telegram_kpi

# --- Telegram Bot ---
# Lấy token từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=8921839357:AAGGeitX7Nx6lA39M6rD0s2PXVERQa9iu-M

# --- API Server ---
# Cổng chạy Express API (mặc định 3000)
API_PORT=3001

# --- Google Sheets Integration ---
# ID của Google Spreadsheet chính (KPI data)
GOOGLE_SPREADSHEET_ID=1KN4aUy6dPBgmg0n5hE1zaGuXZdtEKvcxyB7XQF-jft8

# ID của Google Spreadsheet phụ (Customer data)
CUSTOMER_SPREADSHEET_ID=1THw3jeGOlQVgqVBwiz2gvZpiLzsfs0PRl4Odq92Jbso

# --- Telegram Admin IDs ---
# Danh sách Telegram User ID của admin, cách nhau bằng dấu phẩy
ADMIN_IDS=5491701007,8492139644,1801644744,8634311806

# --- Cloudflare Tunnel (tuỳ chọn) ---
# Lấy token tại: https://one.dash.cloudflare.com → Tunnels → Create a tunnel
# Chỉ cần điền nếu muốn expose Mini App ra Internet
CLOUDFLARE_TUNNEL_TOKEN=

# URL mini app (để trống nếu dùng Cloudflare tunnel, nó tự cập nhật)
MINI_APP_URL=

# --- Node.js Network Fix ---
# Sửa lỗi IPv6/DNS khi kết nối Telegram API
NODE_OPTIONS="--dns-result-order=ipv4first --no-network-family-autoselection"

# --- Feature Flags ---
# Tắt kiểm tra duplicate ảnh (true/false)
DISABLE_IMAGE_DUPLICATE_CHECK=false

# --- Logging ---
# Đường dẫn file log của API Server
APIS_LOG_FILE=./logs/timekeep_api_logs.log
# Đường dẫn file log của Telegram Bot
BOTS_LOG_FILE=./logs/timekeep_bot_logs.log


